{
  "description": "Каждый раз, когда пользователь нажимает на дизлайк внизу экрана сторис",
  "properties": {
    "amount": {
      "description": "Сколько всего слайдов в сторис",
      "type": "number"
    },
    "position": {
      "description": "Позиция слайда",
      "type": "number"
    },
    "story_name": {
      "description": "Заголовок истории",
      "type": "string"
    },
    "shelf_position": {
      "description": "На какой позиции находится полка с историями",
      "type": "number"
    },
    "story_type": {
      "description": "Страница, на которой показана история",
      "type": "string",
      "enum": [
        "loyalty",
        "main_page",
        "retailer_page",
        "onboarding",
        "promo_macro_page"
      ]
    },
    "source_identifier": {
      "description": "Идентификатор источника, где была увидена сторис",
      "type": "string",
      "$comment": "deeplink макроакции, если story_type = promo_macro_page"
    },
    "viewed_story": {
      "description": "id сторис, который просматривает юзер",
      "type": "number"
    }
  },
  "required": [
    "amount",
    "position",
    "story_type",
    "viewed_story"
  ],
  "title": "Story Dislike Clicked",
  "type": "object"
}