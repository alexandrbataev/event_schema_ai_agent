  "properties": {
    "id": {
      "description": "id доступного магазина",
      "type": "number"
    },
    "uuid": {
      "description": "uuid доступного магазина",
      "type": "string"
    },
    "tab": {
      "description": "вкладка, на которой доступен магазин",
      "type": "string"
    },
    "position": {
      "description": "позиция доступного на вкладке магазина",
