{
  "title": "AvailableRetailers",
  "type": "object",
  "description": "Массив с инфой о доступных ритейлерах",
  "properties": {
    "retailer_name": {
      "description": "Имя ретейлера",
      "type": "string"
    },
    "retailer_id": {
      "description": "Идентификатор ритейлера",
      "type": "number"
    },
    "position": {
      "description": "Позиция магазина на странице, нумерация с 1",
      "type": "number"
    },
    "pickup_available": {
      "description": "1 - если доступен самовывоз, 0 иначе",
      "type": "boolean"
    },
    "by_courier_available": {
      "description": "1 - если доступна доставка, 0 иначе",
      "type": "boolean"
    }
  },
  "required": [
