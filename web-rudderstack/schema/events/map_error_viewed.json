{
  "description": "Показана ошибка при просмотре карты",
  "properties": {
    "map_type": {
      "description": "На какой карте была показана ошибка (самовывоз или доставка)",
      "type": "string",
      "enum": [
        "pickup",
        "delivery"
      ]
    },
    "error_type": {
      "description": "Какой тип ошибки показан пользователю",
      "type": "string",
      "enum": [
        "no_pickup",
        "zoom",
        "other"
      ],
      "$comment": "no_pickup - нет магазинов самовывоза; zoom - приблизьте карту"
    },
    "error_text": {
      "description": "Текст ошибки",
      "type": "string"
    }
  },
  "required": [
    "map_type",
    "error_type",
    "error_text"
  ],
  "title": "Map Error Viewed",
  "type": "object"
}