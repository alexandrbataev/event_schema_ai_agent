{
  "title": "ContextTraits",
  "type": "object",
  "description": "Контекстуальные поля отражающие состояние приложения",
  "properties": {
    "eventTenant": {
      "description": "Тенант",
      "type": "string",
      "enum": [
        "sbermarket",
        "smbusiness",
        "kuper",
        "kuperbusiness"
      ]
    },
    "userId": {
      "description": "UUID Идентификатор пользователя с бекенда",
      "type": "string"
    },
    "storeId": {
      "description": "ID текущего магазина",
      "type": "number"
    },
    "storeUuid": {
      "description": "UID текущего магазина",
      "type": "string"
    },
    "retailerId": {
      "description": "ID текущего ритейлера",
      "type": "number"
    },
    "orderId": {
      "description": "ID текущего заказа",
      "type": "string"
    },
    "sessionId": {
      "description": "UUID аналитической сессии",
      "type": "string"
    },
    "shippingMethodKind": {
      "description": "Выбранный метод доставки",
      "type": "string"
    },
    "openMode": {
      "description": "Режим открытия приложения",
      "type": "string",
      "enum": [
        "web",
        "pwa",
        "iframe",
        "webview"
      ]
    },
    "embeddingPlatform": {
      "description": "Платформа, интеграции приложения",
      "type": "string"
    },
    "companyId": {
      "description": "Идентификатор компании (для b2b)",
      "type": "string"
    },
    "release": {
      "description": "Номер релиза приложения",
      "type": "string"
    },
    "targetDevice": {
      "description": "Целевой вариант отображения: десктоп или мобильное устройство",
      "type": "string",
      "enum": [
        "desktop",
        "mobile"
      ]
    }
  }
}
