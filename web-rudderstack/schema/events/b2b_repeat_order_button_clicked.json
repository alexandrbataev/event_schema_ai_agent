{
  "description": "Нажатие на кнопку Повторить заказ",
  "properties": {
    "order_number": {
      "description": "Номер повторяемого заказа",
      "type": "string"
    },
    "source": {
      "description": "Источник (страница) откуда нажата кнопка повторить заказ",
      "type": "string",
      "enum": [
        "company_history",
        "order_cart",
        "landing_last_shipment_widget",
        "profile_last_shipment_widget"
      ]
    },
    "cart_order_items": {
      "description": "Массив со списоком товаров, добавленных по кнопке Повторить заказ",
