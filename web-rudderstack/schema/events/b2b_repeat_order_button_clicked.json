      "items": {
        "type": "object",
        "description": "Товар",
        "properties": {
          "item_id": {
            "description": "ID товара",
            "type": "number"
          },
          "item_name": {
            "description": "Название товара",
            "type": "string"
          }
        }
      }
    },
    "retailer_id": {
      "description": "ID ритейлера повторного заказа в корзине",
      "type": "number"
    },
    "retailers_prices": {
